#!/bin/sh
# Rocket.Chat - Self-signed HTTPS deployment
# Deploy with: docker compose -f compose.database.yml -f compose.traefik.yml -f compose.yml up -d

REG_TOKEN=
DOMAIN=localhost
ROOT_URL=https://localhost
RELEASE=8.0.1

# Self-Signed cert by default
LETSENCRYPT_ENABLED=false
LETSENCRYPT_EMAIL=demo@email.com
TRAEFIK_PROTOCOL=https
ENABLE_JITSI=false

# Prometheus
PROMETHEUS_RETENTION_SIZE=15GB
PROMETHEUS_RETENTION_TIME=15d
# default prometheus port (9090) conflicts with cockpit in centos
PROMETHEUS_PORT=9000
# Grafana
# Set to empty string to use a subpath
GRAFANA_DOMAIN=
# set to /grafana to use from a subpath
GRAFANA_PATH=/grafana

# Default Grafana Login is admin:pass
GRAFANA_ADMIN_PASSWORD=pass
GRAFANA_HOST_PORT=5050
GRAFANA_BIND_IP=127.0.0.1

# Traefik ports
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_HTTPS_PORT=443

# Jitsi
# Set ENABLE_JITSI=true and include compose.jitsi.yml to enable the Jitsi stack
JITSI_IMAGE_VERSION=stable-10741
JITSI_DOMAIN=meet.localhost
JITSI_PUBLIC_URL=https://meet.localhost
# Required for calls with more than 2 participants or LAN/NAT deployments.
# Set this to the host IP address clients use to reach the Docker host.
JITSI_JVB_ADVERTISE_IPS=
# Required service passwords. Set strong unique values before enabling Jitsi.
JITSI_JICOFO_AUTH_PASSWORD=
JITSI_JVB_AUTH_PASSWORD=

# MongoDB
MONGODB_BIND_IP=127.0.0.1
MONGODB_PORT_NUMBER=27017

# NATS
NATS_PORT_NUMBER=4222
NATS_BIND_IP=127.0.0.1

# SMTP Configuration
# Leave blank to skip SMTP configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@localhost
# Protocol: smtp or smtps
SMTP_PROTOCOL=smtp
# Set to true to ignore TLS/SSL errors (not recommended for production)
SMTP_IGNORE_TLS=false
